# Backend Environment Variables Template

# Database
# For SQLite: sqlite:///./samruddhi.db
# For PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/samruddhi

# Security
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=yoursecretkeyhere

# CORS / URLs
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000
FRONTEND_URL=https://yourdomain.com

# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@yourdomain.com

