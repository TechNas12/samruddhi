# Frontend Environment Variables Template

# Base URL for the Backend API
# Leave EMPTY for local dev (Next.js rewrites handle proxying to localhost:8000)
# For production CI/CD builds, this is set in the deploy.yml workflow:
#   NEXT_PUBLIC_API_URL=https://www.api.samruddhiorganics.shop
NEXT_PUBLIC_API_URL=

# Supabase Storage (Client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
